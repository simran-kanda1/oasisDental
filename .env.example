# Firebase Web config (safe for client, but keep in env for portability)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Functions region (optional)
# VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# Wix API secrets MUST stay server-side in Firebase Functions (not in this file):
# firebase functions:secrets:set WIX_API_KEY
# firebase functions:secrets:set WIX_SITE_ID
# Site id for Oasis Dental (secret only — do NOT add WIX_SITE_ID to functions/.env.*):
